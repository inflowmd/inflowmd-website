# ──────────────────────────────────────────────────────────────────────
# CVC SEO Dashboard environment variables
# Copy to .env.local for local development, and mirror in Vercel dashboard.
# ──────────────────────────────────────────────────────────────────────

# Google Cloud service account (same account for all three Google APIs)
GOOGLE_SERVICE_ACCOUNT_EMAIL=cvc-dashboard@your-project.iam.gserviceaccount.com
# Paste the private_key value from the downloaded JSON key, keeping the
# literal \n sequences — the code normalizes them to real newlines at runtime.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_PROJECT_ID=your-google-project-id

# Google Search Console
# For a domain property use "sc-domain:comprehensivevein.care";
# for a URL-prefix property use the full origin.
GSC_SITE_URL=sc-domain:comprehensivevein.care

# Google Analytics 4 (numeric property ID, with or without the "properties/" prefix)
GA4_PROPERTY_ID=properties/000000000

# Google Business Profile location (from business.google.com → Profile strength)
GBP_LOCATION=locations/0000000000000000000

# Optional — manually maintained review snapshot.
# Omit any of these to hide the review card on the dashboard.
GBP_REVIEWS_AVERAGE=4.9
GBP_REVIEWS_TOTAL=47
GBP_REVIEWS_NEW_THIS_QUARTER=8

# Dashboard access
# Plain password the user types on the sign-in page.
DASHBOARD_PASSWORD=choose-a-strong-shared-password
# Random ≥16-char secret used to sign the session cookie. Rotate to log everyone out.
DASHBOARD_SESSION_SECRET=generate-a-long-random-string-here
